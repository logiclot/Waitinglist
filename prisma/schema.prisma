// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  USER        // Default, pre-onboarding
  BUSINESS
  EXPERT
  ADMIN
}

enum SpecialistStatus {
  PENDING_REVIEW
  APPROVED
  SUSPENDED
}

enum OrderStatus {
  draft
  paid_pending_implementation
  in_progress
  delivered
  revision_requested
  approved
  refunded
  disputed
}

enum MessageType {
  user
  system
  bid_card
  order_card
}

enum DemoVideoStatus {
  none
  pending
  approved
  rejected
}

enum JobStatus {
  draft
  pending_payment
  open
  closed
  awarded
  cancelled
  full
}

enum BidStatus {
  submitted
  shortlisted
  rejected
  accepted
  withdrawn
}

enum SpecialistTier {
  STANDARD
  PROVEN
  ELITE
}

// User & Auth
model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String
  profileImageUrl       String?   // Avatar URL (Supabase storage or similar)
  emailVerifiedAt       DateTime?
  role                  Role      @default(USER)
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  businessProfile       BusinessProfile?
  specialistProfile     SpecialistProfile?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  
  // Messaging & Orders
  buyerOrders           Order[]   @relation("BuyerOrders")
  buyerConversations    Conversation[] @relation("BuyerConversations")
  
  // Jobs
  postedJobs            JobPost[] @relation("BuyerJobs")

  // Sent messages
  sentMessages          Message[]

  // Saved Solutions
  savedSolutions        SavedSolution[]

  // Notifications
  notifications         Notification[]

  // Feedback
  feedbackSubmissions   Feedback[]
  surveyCompletions     SurveyCompletion[]

  // Referral System
  referralCode          String?   @unique @default(uuid())
  referredBy            String?   // The referral code of the user who referred this user
  referralRewards       Json?     // { expertDiscountCount: Int, businessDiscountCount: Int }
  
  // Tracking for referral conditions
  lastLoginAt           DateTime?
  loginDaysCount        Int       @default(0)
  referralCompletedAt   DateTime? // When the referral reward was granted to the referrer

  // Invoice tracking
  lastInvoiceViewedAt   DateTime? // When user last visited the Invoices tab (for unread badge)
  // Jobs tracking (expert — unseen open jobs badge)
  lastJobsViewedAt      DateTime? // When expert last visited Find Work (for new-jobs badge)

  // OAuth account linking
  accounts              Account[]
}

// NextAuth-standard Account model — tracks linked OAuth providers per user.
// Allows a single user to sign in via Google, LinkedIn, or credentials without
// creating duplicate DB rows. Prevents orphaned sessions when tokens expire.
model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String  // "oauth" | "credentials"
  provider          String  // "google" | "linkedin" | "credentials"
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  type      String   // info, success, alert
  isRead    Boolean  @default(false)
  actionUrl String?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model BusinessProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName      String
  lastName       String
  companyName    String
  jobRole        String
  howHeard       String
  interests      String[]
  tools          String[] // New field for "Tools you use"
  industry       String?
  companySize    String?
  whatToAutomate String?
  timezone       String?
  billingEmail   String?  // New field for billing contact
  website        String?  // New field
  country        String?

  // Invoice fields
  invoiceAddress            String?  // Full billing address for invoices
  invoiceVatNumber          String?  // VAT/Tax ID if applicable
  invoiceRegistrationNumber String?  // Company registration number (e.g. CRO, KvK)
  
  // Onboarding Refinement fields
  businessPrimaryProblems String[]
  successDefinition       String[]
  decisionContext         String?
  upgradeInterests        String[]
  timingPreference        String?

  // Stripe Customer
  stripeCustomerId        String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SpecialistProfile {
  id                        String    @id @default(uuid())
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Public URL slug
  slug                      String    @unique
  
  // Profile Fields
  legalFullName             String
  displayName               String
  country                   String
  timezone                  String?
  isAgency                  Boolean   @default(false)
  agencyName                String?
  agencyTeamSize            String?   // New
  businessIdentificationNumber String? // New
  
  phoneNumber               String?
  
  primaryTool               String?   // New
  tools                     String[]  // Secondary tools
  specialties               String[]  // Kept for backward compat or extra metadata
  availability              String?   // Weekly capacity
  
  yearsExperience           String
  
  portfolioLinks            Json      // Stored as JSON array of objects or strings
  portfolioUrl              String?   // New: Primary portfolio URL
  
  pastImplementations       String    // "Approx number of implementations"
  typicalProjectSize        String?   // New
  clientAcquisitionSource   String[]  // New
  
  bio                       String?   // Short bio for public profile
  responseTime              String?   // e.g. "Within 2 hours"
  
  // Status & Badges
  status                    SpecialistStatus @default(PENDING_REVIEW)
  tier                      SpecialistTier   @default(STANDARD)
  verified                  Boolean   @default(false)
  businessVerified          Boolean   @default(false)
  foundingRank              Int?      @unique
  completedSalesCount       Int       @default(0)
  commissionOverridePercent Decimal?  @db.Decimal(5, 2)

  // Elite Application
  eliteApplicationStatus    String?   // pending, approved, denied
  eliteAppliedAt            DateTime?
  eliteDeniedAt             DateTime?
  eliteDeniedReason         String?
  eliteDemotedAt            DateTime?
  eliteDemotedReason        String?

  // New Expert Boost
  newExpertBoostUntil       DateTime? // 7 days after approval

  // Legal & Compliance
  legalStatus               String    @default("pending_acceptance") // pending_acceptance, accepted
  termsAcceptedAt           DateTime?
  authorityConsent          Boolean   @default(false) // New
  marketingConsent          Boolean   @default(false)

  // Stripe Connect
  stripeAccountId           String?
  stripeDetailsSubmitted    Boolean   @default(false)
  stripeChargesEnabled      Boolean   @default(false)
  stripePayoutsEnabled      Boolean   @default(false)
  
  // Founding Expert Campaign
  isFoundingExpert          Boolean   @default(false)
  platformFeePercentage     Int       @default(16)  // Denormalized cache of commission rate for display

  // Calendar
  calendarUrl               String?   // e.g. Calendly link

  // Invoice template (for sellers to issue invoices to buyers)
  invoiceCompanyName        String?   // Legal/trading name for invoices
  invoiceAddress            String?   // Full address for invoices
  invoiceVatNumber          String?   // VAT/Tax ID if applicable

  // Portfolio Customization
  portfolioBackground       String?   // "gradient_default" | "grid" | "dots" | "wave" | "stripe"
  portfolioBorderColor      String?   // hex from preset palette, e.g. "#8DC63F"
  portfolioFont             String?   // "default" | "inter" | "dm_sans" | "space_grotesk" | "lora" | "jetbrains_mono"
  portfolioCoverImage       String?   // Supabase public URL for hero cover image
  portfolioBackgroundColor  String?   // hex color for full page background, e.g. "#F0FDF4"
  portfolioPatternColor     String?   // hex color for background pattern, e.g. "#64748B"
  featuredSolutionIds       String[]  // Max 2 pinned solution IDs (shown first on portfolio)
  portfolioViewCount        Int       @default(0)

  // Bid quality moderation
  bidBannedUntil            DateTime? // Set when expert accumulates too many thumbs-down

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  // Relations
  solutions                 Solution[]
  sellerOrders              Order[]   @relation("SellerOrders")
  conversations             Conversation[] @relation("SellerConversations")
  bids                      Bid[]     @relation("SpecialistBids")
  ecosystems                Ecosystem[]
  sentEcoInvites            EcosystemInvite[] @relation("SentEcoInvites")
  receivedEcoInvites        EcosystemInvite[] @relation("ReceivedEcoInvites")
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Marketplace Core
model Solution {
  id                            String    @id @default(uuid())
  expertId                      String
  expert                        SpecialistProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  slug                          String    @unique
  title                         String
  shortSummary                  String?
  outcome                       String?   // "Outcome Line" e.g. "Reduces manual lead handling for sales teams."
  description                   String
  longDescription               String?   // Detailed SEO description
  complexity                    String?   // Simple, Standard, Advanced
  
  category                      String
  integrations                  String[]
  
  // Requirements & Access
  requiredInputs                String[]  // sample data, accounts, etc.
  
  // Pricing (Cents)
  implementationPriceCents      Int
  monthlyCostMinCents           Int?
  monthlyCostMaxCents           Int?
  
  deliveryDays                  Int
  supportDays                   Int       @default(30) // Mandatory support duration (15, 30, 60)

  included                      String[]
  excluded                      String[]
  faq                           Json?     // Array of {question, answer}
  status                        String    @default("draft") // draft, published, paused, archived
  publishedAt                   DateTime?
  
  // Moderation
  moderationStatus              String    @default("pending") // auto_approved, pending, approved, rejected
  approvedAt                    DateTime?

  // Content Fields
  outline                       String[] // Up to 3 highlight lines
  lastStep                      Int      @default(1) // Wizard progress tracking

  // Proof & Trust
  proofType                     String?   // screenshot, case_study, both
  proofContent                  String?   // URL, text, or JSON (for "both")

  // Filters & Search Facets
  businessGoals                 String[]  // Lead gen, Sales auto, etc.
  industries                    String[]  // eCommerce, SaaS, etc.
  paybackPeriod                 String?   // lt_1m, 1_3m, long_term
  trustSignals                  String[]  // NDA included, Zero-data, etc.

  // Solution structure
  structureConsistent           String[]  // "What stays the same"
  structureCustom               String[]  // "What requires customization"
  measurableOutcome             String?   // Numeric/Specific impact
  
  // Milestones (V3)
  milestones                    Json?     // Array of { title, description, priceCents, deliveryTime }

  // Skills — discrete capabilities the automation delivers
  skills                        Json?     // Array of { name, description }

  // Versioning & Maintenance
  version                       Int       @default(1)
  changelog                     String?
  upgradePriceCents             Int?
  
  parentId                      String?
  parent                        Solution? @relation("SolutionVersions", fields: [parentId], references: [id])
  children                      Solution[] @relation("SolutionVersions")

  // Demo Video
  demoVideoUrl                  String?
  demoVideoStatus               DemoVideoStatus @default(none)
  demoVideoReviewedAt           DateTime?
  
  // Demo Booking
  demoPriceCents                Int       @default(200) // Default 2 EUR

  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  
  orders                        Order[]
  conversations                 Conversation[]
  bids                          Bid[]
  savedByUsers                  SavedSolution[]
  ecosystemItems                EcosystemItem[]
  ecosystemInvites              EcosystemInvite[]

  @@index([expertId])
  @@index([status])
  @@index([expertId, status])
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String      // Link to User (Business)
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  
  sellerId        String      // Link to SpecialistProfile
  seller          SpecialistProfile @relation("SellerOrders", fields: [sellerId], references: [id])
  
  solutionId      String?
  solution        Solution?   @relation(fields: [solutionId], references: [id], onDelete: SetNull)

  // For job-based orders (from accepted bid proposals)
  bidId           String?     @unique
  bid             Bid?        @relation(fields: [bidId], references: [id])
  
  priceCents      Int
  status          OrderStatus @default(draft)
  
  deliveryNote    String?
  revisionNote    String?
  revisionCount   Int       @default(0)

  // Milestones — Array of { title, description, priceCents, status, fundedAt, releasedAt }
  milestones      Json?

  // Stripe PaymentIntent ID — needed for refunds
  stripePaymentIntentId  String?

  acceptedAt      DateTime?       // When expert accepted the order
  approvedAt      DateTime?
  refundedAt      DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  conversations   Conversation[]
  review          Review?
  dispute         Dispute?

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([solutionId])
}

// Double-blind review system
model Review {
  id                String    @id @default(uuid())
  orderId           String    @unique
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Seller (expert) reviews the buyer
  sellerRating      Int?      // 1-5
  sellerComment     String?   @db.Text
  sellerSubmittedAt DateTime?

  // Buyer reviews the seller (expert)
  buyerRating       Int?      // 1-5
  buyerComment      String?   @db.Text
  buyerSubmittedAt  DateTime?

  // Unblinding — both parties can see each other's review
  isUnblinded       Boolean   @default(false)
  unblindedAt       DateTime?

  // Admin moderation
  isHidden          Boolean   @default(false)
  hiddenReason      String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// Dispute resolution
model Dispute {
  id              String    @id @default(uuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  reason          String    @db.Text
  status          String    @default("open") // open, investigating, resolved

  buyerStatement  String?   @db.Text  // Buyer's clarification / point of view
  sellerStatement String?   @db.Text  // Expert's clarification / point of view

  adminNotes      String?   @db.Text
  resolution      String?   // full_refund, release_to_seller, partial_refund, dismissed
  resolutionNote  String?   @db.Text
  resolvedBy      String?   // Admin user ID
  resolvedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Conversation {
  id              String      @id @default(uuid())
  buyerId         String      // Usually User ID
  buyer           User        @relation("BuyerConversations", fields: [buyerId], references: [id])
  
  sellerId        String
  seller          SpecialistProfile @relation("SellerConversations", fields: [sellerId], references: [id])
  
  solutionId      String?
  solution        Solution?   @relation(fields: [solutionId], references: [id], onDelete: SetNull)

  orderId         String?
  order           Order?      @relation(fields: [orderId], references: [id])

  jobPostId       String?
  jobPost         JobPost?    @relation(fields: [jobPostId], references: [id])
  
  status          String      @default("active") // active, pending, closed
  
  messages        Message[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([orderId])
  @@index([jobPostId])
  @@index([solutionId])
}

model Message {
  id              String        @id @default(uuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId        String        // User ID or Specialist ID (User ID of specialist)
  user            User          @relation(fields: [senderId], references: [id])
  
  body            String
  type            MessageType   @default(user)

  createdAt       DateTime      @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// Jobs Feature
model JobPost {
  id              String      @id @default(cuid())
  buyerId         String
  buyer           User        @relation("BuyerJobs", fields: [buyerId], references: [id])
  
  title           String
  goal            String      @db.Text
  category        String
  tools           String[]
  budgetRange     String      // "Under $500", "$500–$1,500", etc.
  timeline        String      // "ASAP", "1–2 weeks", etc.
  
  status          JobStatus   @default(draft)
  
  viewCount       Int         @default(0)
  
  // Payment
  paidAt          DateTime?
  paymentProvider String?
  paymentIntentId String?

  // Rejection (business chose none of the proposals)
  rejectionFeedback String?   @db.Text
  rejectedAt        DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  bids            Bid[]
  conversations   Conversation[]

  @@index([buyerId])
  @@index([status])
  @@index([buyerId, status])
}

model Bid {
  id              String      @id @default(cuid())
  jobPostId       String
  jobPost         JobPost     @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  
  specialistId    String
  specialist      SpecialistProfile @relation("SpecialistBids", fields: [specialistId], references: [id])
  
  solutionId      String?
  solution        Solution?   @relation(fields: [solutionId], references: [id], onDelete: SetNull)

  message         String      @db.Text
  proposedApproach String?    @db.Text
  estimatedTime   String
  priceEstimate   String?
  
  status          BidStatus   @default(submitted)

  // Business owner feedback on this proposal
  feedback        String?     // "up" | "down"
  feedbackAt      DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  order           Order?

  @@unique([jobPostId, specialistId])
  @@index([solutionId])
}

model SavedSolution {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  solutionId String
  solution   Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, solutionId])
}

// Waitlist
model WaitlistSignup {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now())
  fullName     String
  email        String    @unique
  role         String    // 'business' | 'expert'
  source       String?   // 'landing_waitlist'
  consent      Boolean   @default(true)
  inviteToken  String?   @unique
  inviteSentAt DateTime?
  usedAt       DateTime?
}

// Ecosystems (Bundles)
model Ecosystem {
  id            String   @id @default(cuid())
  expertId      String
  expert        SpecialistProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)

  title         String
  slug          String   @unique
  shortPitch    String   // 1-2 lines (max 140)
  businessGoal  String   // e.g. "Lead generation"
  outcomes      String?  // small bullet list, store as newline-separated or JSON
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Bundle discount — expert sets a custom total price lower than sum of parts
  bundlePriceCents        Int?
  // Extended support packages — flat price per tier (6 or 12 months)
  extSupport6mCents       Int?
  extSupport12mCents      Int?
  extSupportDescription   String?  // What extended support includes

  items         EcosystemItem[]
  invites       EcosystemInvite[]
}

// Feedback (free text, 3 per day per user)
model Feedback {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  role      String   // "EXPERT" | "BUSINESS" - snapshot at submission
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Survey completion (first time = 5% coupon)
model SurveyCompletion {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   Json     // { q1: number|string, q2: ..., ... }
  role      String   // "EXPERT" | "BUSINESS" at completion
  createdAt DateTime @default(now())
}

model EcosystemItem {
  id          String   @id @default(cuid())
  ecosystemId String
  solutionId  String
  position    Int      @default(0)
  note        String?  // optional “Why this is included”
  createdAt   DateTime @default(now())

  ecosystem   Ecosystem @relation(fields: [ecosystemId], references: [id], onDelete: Cascade)
  solution    Solution  @relation(fields: [solutionId], references: [id], onDelete: Cascade)

  @@unique([ecosystemId, solutionId])
  @@index([solutionId])
}

// Suite Partnership Invites
model EcosystemInvite {
  id           String   @id @default(cuid())
  ecosystemId  String
  ecosystem    Ecosystem @relation(fields: [ecosystemId], references: [id], onDelete: Cascade)
  solutionId   String
  solution     Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  inviterId    String
  inviter      SpecialistProfile @relation("SentEcoInvites", fields: [inviterId], references: [id])
  inviteeId    String
  invitee      SpecialistProfile @relation("ReceivedEcoInvites", fields: [inviteeId], references: [id])
  status       String   @default("pending") // pending | accepted | declined | withdrawn
  message      String?  // Optional note from suite owner
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ecosystemId, solutionId])
  @@index([inviteeId, status])
  @@index([ecosystemId, status])
}

// ── Traffic Analytics ────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(uuid())
  sessionId String   // browser sessionStorage ID (persists per tab)
  pathname  String
  referrer  String?  // document.referrer (external referrer on first hit)
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([pathname])
  @@index([createdAt])
}

// ── Audit Quiz Analytics ─────────────────────────────────────────────────────

model AuditEvent {
  id         String   @id @default(uuid())
  sessionId  String
  event      String   // "quiz_start" | "step_complete" | "quiz_complete" | "email_sent"
  step       Int?
  score      Int?
  scoreLabel String?
  answers    Json?
  email      String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([sessionId])
  @@index([createdAt])
}
